#include<iostream>
using namespace std;

int main()
{
	int number, sum = 0;

	cout <<"\nEven Numbers between 0 and 100 = ";
	for(number = 1; number <= 100; number++)
	{
  		if ( number % 2 == 0 ) 
		{
  			cout << number << " ";
			sum = sum + number;
		}
	}
	
	cout << "\nThe Sum of All Even Numbers between 1 and 100 = " << sum;
	
 	return 0;
}
